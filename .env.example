# Copy to ".env" and edit (never commit ".env").
#
# --- OpenRouter (recommended if you use an OpenRouter key) ---
# Put your OpenRouter secret in OPENAI_API_KEY (same env var name; the client is OpenAI-compatible).
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
# Must be an OpenRouter model id, e.g. openai/gpt-4o-mini, anthropic/claude-3-haiku, meta-llama/llama-3.1-8b-instruct
LLM_MODEL=openai/gpt-4o-mini

# Optional OpenRouter headers (some accounts benefit from referer for rankings)
# OPENROUTER_HTTP_REFERER=https://yoursite.com
# OPENROUTER_APP_TITLE=AI Guru v2

# --- OpenAI direct (alternative: comment out OPENAI_BASE_URL above) ---
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# --- API CORS (browser dev server, e.g. Vite on :5173) ---
# Comma-separated. Defaults to localhost/127.0.0.1:5173 if unset.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Retrieval (sentence-transformers query encoding) ---
# Optional torch device for embedding the user query (FAISS search). Use cuda on NVIDIA GPU.
# Must match a device PyTorch can use; index vectors are unchanged (still loaded from disk).
# AI_GURU_EMBED_DEVICE=cuda
